# Marketplace APIs
EBAY_ENV=sandbox
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
EBAY_MARKETPLACE_ID=EBAY_US
# Optional for manual testing only; generate short-lived tokens from the credentials above.
EBAY_OAUTH_APPLICATION_TOKEN=

BESTBUY_API_KEY=
APIFY_API_KEY=
APIFY_BESTBUY_ACTOR=axlymxp/bestbuy-scraper

# Amazon Creators API (PA-API was retired May 15, 2026)
AMAZON_CREATORS_CREDENTIAL_ID=
AMAZON_CREATORS_CREDENTIAL_SECRET=
AMAZON_PARTNER_TAG=

# Open product specifications
ICECAT_USERNAME=
WIKIDATA_USER_AGENT=

# Supabase client values
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Server/CLI only — never expose these in a browser bundle
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_PROJECT_REF=
SUPABASE_DB_PW=
SUPABASE_CONNECTION_STRING=

# Daily Discord workflow (server-side only)
DISCORD_DAILY_WEBHOOK_URL=
DISCORD_GPU_DESK_CHANNEL_ID=
# Command invoked by the OpenShell/HiddenLayer research boundary. Must print a JSON array.
OPEN_SHELL_RESEARCH_COMMAND=
